{
  "name": "NoteManager",
  "version": "1.0",
  "description": "Ein Tool zum Erstellen, Speichern und Lesen von Notizen.",
  "tools": [
    {
      "name": "save_note",
      "description": "Speichert Text als .txt Datei.",
      "parameters": {
        "type": "object",
        "properties": {
          "filename": { "type": "string", "description": "Dateiname" },
          "content": { "type": "string", "description": "Notizinhalt" }
        },
        "required": ["filename", "content"]
      }
    },
    {
      "name": "read_note",
      "description": "Öffnet den Dateimanager, um eine .txt Datei zu lesen.",
      "parameters": {
        "type": "object",
        "properties": {
          "filename": { "type": "string", "description": "Optionaler Name der Datei" }
        }
      }
    }
  ],
  "entry": "logic.js"
}